# ============================================================
# GITIGNORE FILE
# This file tells Git which files and folders should not be
# tracked, committed, or uploaded to GitHub.
# It helps keep the repository clean and prevents private,
# temporary, generated, or computer-specific files from being
# included in the submitted project.
# Important:
# The .gitignore file itself should be committed to GitHub.
# Also note:
# If a file was already committed before it was added here,
# Git may continue tracking it. It must first be removed from
# Git's tracking history using a command such as:
# git rm --cached filename
# The file can remain on the local computer after that command.
#=================================================================


# == PYTHON CACHE FILES ==#
# Python automatically creates __pycache__ folders when code runs.
# These folders only contain temporary compiled files, so they are not needed in GitHub.
__pycache__/

# Ignores compiled Python files such as .pyc, .pyo, and .pyd files.
# These files are generated automatically and can be recreated when the project runs.
*.py[cod]

# Ignores Python class files that may be generated by some tools or environments.
# These are temporary build files and should not be included in the repository.
*$py.class

# == VIRTUAL ENVIRONMENT ==#
# Ignores a virtual environment folder named .venv.
# The virtual environment contains installed packages specific to my computer.
.venv/

# Ignores a virtual environment folder named venv.
# Other users should create their own virtual environment using requirements.txt.
venv/

# Ignores a virtual environment folder named env.
# This prevents large dependency folders from being uploaded to GitHub.
env/

# == ENVIRONMENT VARIABLES AND SECRET INFORMATION ==#
# Ignores the main .env file.
# This file may contain private values such as SECRET_KEY, database passwords, and email credentials.
.env

# Ignores other environment files such as .env.local, .env.production, or .env.development.
# These files may also contain private configuration information.
.env.*

# The exclamation mark creates an exception.
# This means .env.example will still be uploaded to GitHub.
# It should contain placeholder variable names, but never real passwords or secret values.
!.env.example


# == DJANGO LOCAL DATABASE ==#
# Ignores the local SQLite database file created during development.
# My final application uses PostgreSQL, and the local database may contain test or personal data.
db.sqlite3

# == DJANGO GENERATED AND UPLOADED FILES ==#
# Ignores the staticfiles folder created by Django's collectstatic command.
# This folder is generated automatically during deployment and does not need to be stored in GitHub.
staticfiles/

# Ignores user-uploaded media files.
# These files may be large, temporary, private, or different between development and production.
media/

# == LOCAL SETTINGS ==#
# Ignores a local Django settings file.
# This file may contain computer-specific settings or private development configuration.
local_settings.py

# == LOG FILES ==#
# Ignores all files ending in .log.
# Log files are generated while the application runs and can become large over time.
*.log

# == MACOS SYSTEM FILES ==#
# Ignores .DS_Store files automatically created by macOS Finder.
# These files only store folder display preferences and are not part of the application.
.DS_Store

# == CODE EDITOR AND IDE FILES ==#
# Ignores Visual Studio Code workspace settings.
# These settings may be personal to my computer and are not required to run the project.
.vscode/

# Ignores JetBrains IDE settings used by tools such as PyCharm or IntelliJ.
# These files contain local editor preferences rather than application code.
.idea/